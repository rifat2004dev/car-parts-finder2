from __future__ import annotations

from urllib.parse import quote_plus, urljoin

from bs4 import Tag

from config import MAX_PAGES_PER_SOURCE
from models import Listing
from scraper.base import BaseScraper
from utils import contains_query_keyword, extract_price, infer_car_model, is_http_url, polite_delay, query_variants


class OnlineCarPartsScraper(BaseScraper):
    source_name = 'online_car_parts'
    base_url = 'https://www.onlinecarparts.co.za'

    def scrape(self) -> list[Listing]:
        listings: list[Listing] = []
        seen: set[str] = set()

        for variant in query_variants(self.query):
            total_hits = 0
            for page in range(1, MAX_PAGES_PER_SOURCE + 1):
                url = f'{self.base_url}/search?controller=search&s={quote_plus(variant)}&page={page}'
                response = self.get(url)
                soup = self.soup(response.text)
                cards = soup.select('article.product-miniature, .js-product-miniature, .product, li.product')
                page_hits = 0
                for card in cards:
                    if not isinstance(card, Tag):
                        continue
                    anchor = card.select_one('a[href]')
                    if not anchor:
                        continue
                    href = urljoin(self.base_url, anchor.get('href', '').strip())
                    title = anchor.get('title', '').strip() or anchor.get_text(' ', strip=True)
                    if not title or href in seen or not is_http_url(href) or not contains_query_keyword(title, self.query):
                        continue
                    price = extract_price(card.get_text(' ', strip=True))
                    listings.append(
                        Listing.create(
                            search_query=self.query,
                            part_name=title,
                            car_model=infer_car_model(title, self.query),
                            price=price,
                            location='Delivery to Western Cape',
                            source='Online Car Parts',
                            url=href,
                        )
                    )
                    seen.add(href)
                    page_hits += 1
                total_hits += page_hits
                if page_hits == 0:
                    break
                polite_delay()
            if total_hits:
                break
        return listings
